{
  "name": "rwsite/wp-field",
  "description": "WP_Field v4 HTML fields library for WordPress with fluent API, 52 field types, legacy compatibility, React/Vanilla integrations, conditional logic, and storage strategies.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "wordpress",
    "fields",
    "forms",
    "metabox",
    "settings",
    "laravel",
    "fluent",
    "repeater",
    "flexible-content",
    "react"
  ],
  "homepage": "https://github.com/rwsite/wp-field-plugin",
  "authors": [
    {
      "name": "Aleksei Tikhomirov",
      "email": "alex@rwsite.ru",
      "homepage": "https://rwsite.ru",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/rwsite/wp-field-plugin/issues",
    "source": "https://github.com/rwsite/wp-field-plugin"
  },
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "pestphp/pest": "^4.1",
    "laravel/pint": "^1.16",
    "phpunit/phpunit": "12.4.1",
    "phpstan/phpstan": "^1.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "rector/rector": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "WpField\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WpField\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "./vendor/bin/pest --configuration phpunit.xml",
    "test:unit": "./vendor/bin/pest --configuration phpunit.xml --filter=Unit",
    "test:feature": "./vendor/bin/pest --configuration phpunit.xml --filter=Feature",
    "test:coverage": "./vendor/bin/pest --configuration phpunit.xml --coverage-html coverage/ --coverage-clover coverage/clover.xml --coverage-text --coverage --min=95",
    "analyse": "./vendor/bin/phpstan analyse --memory-limit=1G",
    "lint": "./vendor/bin/pint",
    "lint:check": "./vendor/bin/pint --test -v",
    "rector:dry-run": "./vendor/bin/rector process --config=rector.php --dry-run",
    "rector": "./vendor/bin/rector process --config=rector.php",
    "quality": [
      "@lint:check",
      "@analyse",
      "@rector:dry-run"
    ],
    "quality:fix": [
      "@lint",
      "@rector"
    ],
    "ci": [
      "@test",
      "@quality"
    ],
    "ci:fix": [
      "@quality:fix",
      "@ci"
    ]
  },
  "scripts-descriptions": {
    "test": "Запуск PEST тестов",
    "test:unit": "Запуск Unit тестов",
    "test:feature": "Запуск Feature тестов",
    "test:coverage": "Запуск тестов с отчётом покрытия",
    "lint": "Форматирование кода через Pint",
    "lint:check": "Проверка форматирования кода",
    "rector:dry-run": "Проверка Rector без изменений",
    "rector": "Запуск Rector с применением изменений",
    "quality": "Полная проверка качества кода",
    "quality:fix": "Автоисправление качества кода",
    "ci": "Полный CI-пайплайн",
    "ci:fix": "Автоисправление и прогон CI"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
